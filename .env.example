# Supabase (Client / Vite)
# SECURITY: Never prefix service role keys with VITE_ or expose them in .env files used by the frontend.
# The frontend should only use VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY.
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY


# Access Gate (Piloto)
VITE_ACCESS_GATE_ENABLED=true
VITE_ACCESS_GATE_DAYS_VALID=30

# Feedback WhatsApp
VITE_FEEDBACK_WHATSAPP_ENABLED=true
VITE_FEEDBACK_WHATSAPP_NUMBER=56900000000
VITE_FEEDBACK_WHATSAPP_TEMPLATE=

# Logo.dev
LOGO_DEV_PUBLISHABLE_KEY=pk_your_publishable_key
LOGO_DEV_SECRET_KEY=sk_your_secret_key

# ---
# OpenAI (BACKEND-ONLY)
# NUNCA prefijes esta clave con VITE_. Cualquier var con prefijo VITE_
# termina embebida en el bundle JS y es visible para cualquier usuario del navegador.
# Las llamadas a OpenAI se hacen desde supabase/functions/llm-narrative (Edge Function)
# y supabase/functions/insights-generator. Configurar en Supabase con:
#   supabase secrets set OPENAI_API_KEY=sk-proj-...
OPENAI_API_KEY=sk-proj-your-openai-key
