# ============================================================
# Opina+ — env vars reference (template)
# ============================================================
# Este archivo SÍ se commitea: no contiene secretos reales.
# Para dev local:  cp .env.example .env.local  y rellena valores.
#
# Layout:
#   VITE_*   → exposed to browser bundle (público). Configurar en Vercel Env.
#   Otros    → server-only. Configurar en Supabase Edge secrets, NO en Vercel.
#
# Para procedimientos de rotación ver:
#   docs/runbooks/secrets-rotation.md
# ============================================================


# ------------------------------------------------------------
# CLIENT-SIDE (VITE_*) → Vercel Env (Production / Preview / Development)
# ------------------------------------------------------------

# --- Supabase (cliente) ---
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# --- Access Gate (modo piloto) ---
# 'true' obliga a ingresar código en /access. Para dev local poner 'false'.
VITE_ACCESS_GATE_ENABLED=true
VITE_ACCESS_GATE_DAYS_VALID=30

# --- Cloudflare Turnstile (captcha en /register) ---
# Site key es PÚBLICO (queda en el HTML). El secret va en Supabase
# con nombre TURNSTILE_SECRET_KEY.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxx

# --- Sentry (browser SDK) ---
# DSN público. Vacío en dev / staging si no se quiere reportar.
VITE_SENTRY_DSN=

# --- Narrativas LLM ---
# 'llm' usa edge function llm-narrative. Vacío o cualquier otro valor
# usa stub local (heurística sin IA).
VITE_NARRATIVE_PROVIDER=

# --- Feedback FAB (WhatsApp) ---
VITE_FEEDBACK_WHATSAPP_ENABLED=true
VITE_FEEDBACK_WHATSAPP_NUMBER=56900000000


# ============================================================
# SERVER-ONLY (NO usar prefijo VITE_, NO commitear)
# ============================================================
# Estos NO se ponen en Vercel. Viven en Supabase Edge secrets:
#   supabase secrets set OPENAI_API_KEY=sk-proj-...
# Listar:
#   supabase secrets list
# Ver docs/runbooks/secrets-rotation.md para inventario y rotación.
# ------------------------------------------------------------

# --- OpenAI (edge llm-narrative, insights-generator, actualidad-bot, versus-bot) ---
# OPENAI_API_KEY=sk-proj-...

# --- Cloudflare Turnstile (verificación server en register-user) ---
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# --- WhatsApp / Meta (whatsapp-webhook + send-whatsapp-invite) ---
# WHATSAPP_APP_SECRET=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_INVITE_TEMPLATE_NAME=invitaciones_opina_mas_definitivas
# WHATSAPP_INVITE_TEMPLATE_LANG=es_CL

# --- Brandfetch (edge brandfetch-proxy) ---
# BRANDFETCH_API_KEY=

# --- Logo.dev (solo scripts locales tsx scripts/ops/catalog/*) ---
# LOGO_DEV_PUBLISHABLE_KEY=pk_...
# LOGO_DEV_SECRET_KEY=sk_...

# --- Supabase service role (solo scripts locales tsx scripts/ops/*) ---
# JAMÁS en Vercel ni en bundle.
# SUPABASE_SERVICE_ROLE_KEY=
