    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "csv-parser": "^3.2.0",
    "framer-motion": "^11.18.2",
    "idb": "^8.0.3",
    "lucide-react": "^0.563.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.27.0",
    "radix-ui": "^1.4.3",
