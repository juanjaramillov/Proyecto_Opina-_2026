    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.21.3",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
